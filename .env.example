# ============================================================================
# BookGift environment variables
# ============================================================================
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Dashboard -> Project Settings -> API.
# `.env.local` is gitignored. The app falls back to mock data when these are
# unset, so the UI runs without a database during local development.
# ============================================================================

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser. Bypasses Row Level Security.
# Used by the admin client (src/lib/supabase/admin.ts) and seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App base URL — used for auth redirect callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
